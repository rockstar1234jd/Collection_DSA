6. Kadane Circular Quesiton
Link: https://leetcode.com/problems/maximum-sum-circular-subarray/description
Code:
class Solution {
    public int maxSubarraySumCircular(int[] nums) {
        int i = 0;
        int total = nums[i];
        int min = nums[i];
        int max = nums[i];
        int minAns = nums[i];
        int maxAns = nums[i];

        for( i=1; i<nums.length; i++){
            total += nums[i];
            int v1 = nums[i];
            int v2 = max + nums[i];
            int v3 = min + nums[i];

            max = Math.max(v1,v2);
            min = Math.min(v1,v3);
            minAns = Math.min(minAns, min);
            maxAns = Math.max(maxAns, max);
        }
        if(maxAns < 0){
            return maxAns;
        }
            int circular = total - minAns;
            return Math.max(maxAns, circular);
    }
}
