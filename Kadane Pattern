5. Kadane Maximum Absolute Sum
Link: https://leetcode.com/problems/maximum-absolute-sum-of-any-subarray/description/
Code: 
class Solution {
    public int maxAbsoluteSum(int[] nums) {
        int i = 0;
        int noNeg = nums[i];
        int neg = nums[i];
        int res = Math.abs(nums[i]);

        for( i=1; i<nums.length; i++){

            int v1 = nums[i];
            int v2 = noNeg + nums[i];
            int v3 = neg + nums[i];

            noNeg = Math.max(v1,Math.max(v2, v3));
            neg = Math.min(v1,Math.min(v2, v3));
            res = Math.max(res,Math.max(Math.abs(noNeg), Math.abs(neg)));

        } return res;
    }
}

