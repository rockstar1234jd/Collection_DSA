Title: Subarray Product less than k
Link: https://leetcode.com/problems/subarray-product-less-than-k/
Code:
class Solution {
    public int numSubarrayProductLessThanK(int[] nums, int k) {
        if (k <= 1) {
            return 0;
        }

        int left = 0;
        int pro = 1;
        int ans = 0;

        for (int right = 0; right < nums.length; right++) {

            pro *= nums[right];

            while (pro >= k) {
                pro /= nums[left];
                left++;
            }

            ans += right - left + 1;
        }

        return ans;
    }
}
