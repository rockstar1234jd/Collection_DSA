3. Subarray sums divisible by k
Link: https://leetcode.com/problems/subarray-sums-divisible-by-k/description/
Code:
class Solution {
    public int subarraysDivByK(int[] nums, int k) {
        Map<Integer, Integer> map = new HashMap<>();
        int sum = 0;
        int ans = 0;
        map.put(0,1);
        for(int num:nums){
            sum += num;
            int rem = sum % k;
            if(rem<0){
                rem += k;
            }
            if(map.containsKey(rem)){
                ans += map.get(rem);
            }
            map.put(rem,map.getOrDefault(rem, 0)+1);
        } return ans;
    }
} 

Another simple and clean code:
class Solution {
    public int subarraysDivByK(int[] nums, int k) {
        int[] f = new int[k];
        f[0] = 1;
        int sum = 0;
        int ans = 0;
        for (int num : nums) {
            
            sum += num;
            int rem = sum % k;
            
            if (rem < 0) {
                rem += k;
            }
            ans += f[rem];
            f[rem]++;
        }
        return ans;
    }
}

