2.Find the pivot index
Link: https://leetcode.com/problems/find-pivot-index/description/
Code:
class Solution {
    public int pivotIndex(int[] nums) {
        int total = 0;
        // find the total sum.
        for(int num:nums){
            total += num;
        }
        // create the left and right logic
        int left = 0;
        for(int i=0; i<nums.length; i++){
            int right = total - nums[i] - left;
            if(left == right){
                return i;
            }
            left += nums[i];
        }
        return -1;
    }
}
